# Environment
NODE_ENV=development
PORT=3001

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=your_openai_api_key_here

# Image API Keys
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
PEXELS_API_KEY=your_pexels_api_key_here

# Product scraping - ProductScrapes API (primary)
PRODUCTSCRAPES_API_KEY=your_productscrapes_api_key_here
PRODUCTSCRAPES_API_BASE_URL=https://productscrapes.com/api
DISABLE_PRODUCTSCRAPES=false

# Product scraping - Python Scraper Integration
# Choose one of two integration methods:
# Option 1: Flask API (recommended for production - run Python scraper as separate service)
SCRAPER_API_URL=http://localhost:5000
# Option 2: Direct subprocess (for development - calls Python CLI directly)
SCRAPER_USE_SUBPROCESS=true

# Scraping Configuration
GOOGLE_SHOPPING_SCRAPE_TIMEOUT=30000
PRICE_SCRAPE_MAX_WAIT_MS=25000
PRICE_CACHE_TTL=86400
SCRAPER_CACHE_NAMESPACE=productscrapes-v3

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX_REQUESTS=20
AUTH_RATE_LIMIT_DISABLED=false

# Logging
LOG_LEVEL=info
