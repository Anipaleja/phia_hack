# Scraper Configuration

# Logging
LOG_LEVEL=INFO

# Flask API Server
FLASK_PORT=5000
FLASK_DEBUG=false

# Scraper Behavior
SCRAPER_HEADLESS=true
SCRAPER_MAX_CONCURRENT=3

# Proxy (optional - leave empty to disable)
# SCRAPER_PROXY_URL=http://proxy.example.com:8080

# Playwright Configuration
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_WAIT_UNTIL=networkidle

# Node.js Backend Integration
# URL of the Flask scraper API (if running separately)
SCRAPER_API_URL=http://localhost:5000
